# Required only when CLIPFORGE_DOWNLOADER=clipr.
# Copy this file to .env and replace the placeholder with your real key.
CLIPR_API_KEY=your_clipr_api_key_here

# Downloader backend for Twitch clip URLs. Supported: clipr, ytdlp.
# yt-dlp is installed as a Clipforge Python dependency.
CLIPFORGE_DOWNLOADER=ytdlp

# Required for Twitch clip discovery commands.
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# Required only when generating caption metadata with the OpenAI transcription API.
OPENAI_API_KEY=your_openai_api_key_here

# Default transcription model.
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Optional pipeline opt-in. You can also pass --generate-captions per run.
CLIPFORGE_GENERATE_CAPTIONS=false

# Optional TTF/OTF font file for burned-in captions.
# Example on Windows: C:/Windows/Fonts/arial.ttf
CLIPFORGE_CAPTION_FONT_FILE=

# Caption render backend. Supported: drawtext, ass.
# drawtext preserves the original FFmpeg overlay behavior.
CLIPFORGE_CAPTION_RENDERER=drawtext

# Directory for generated ASS subtitle files when CLIPFORGE_CAPTION_RENDERER=ass.
CLIPFORGE_ASS_TEMP_DIR=data/metadata/ass

# Comma-separated font fallback names used in generated ASS style blocks.
CLIPFORGE_CAPTION_FONT_FALLBACKS=Arial

# Subject detection for streamer webcam inference.
# Supported detector values: yolo, haar, none.
CLIPFORGE_SUBJECT_DETECTOR=yolo
CLIPFORGE_YOLO_MODEL=yolo11n.pt
CLIPFORGE_YOLO_DEVICE=auto
CLIPFORGE_YOLO_CONFIDENCE_THRESHOLD=0.30
CLIPFORGE_SUBJECT_SAMPLE_COUNT=12

# Optional streamer-specific PNG watermarks.
# Clipforge looks up {CHANNEL_NAME}_WATERMARK with the channel uppercased.
# Relative paths are resolved from the project root during normal CLI runs.
OHNEPIXEL_WATERMARK=assets/watermarks/ohnepixel.png
DOUBLELIFT_WATERMARK=assets/watermarks/doublelift.png
