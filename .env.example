# Required only when CLIPFORGE_DOWNLOADER=clipr.
# Copy this file to .env and replace the placeholder with your real key.
CLIPR_API_KEY=your_clipr_api_key_here

# Downloader backend for Twitch clip URLs. Supported: clipr, ytdlp.
# yt-dlp is installed as a Clipforge Python dependency.
CLIPFORGE_DOWNLOADER=ytdlp
